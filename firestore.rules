rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaConectado() {
      return request.auth != null;
    }
    function miNomina() {
      return request.auth.token.email.split('@')[0];
    }
    function existeEmpleado(nomina) {
      return exists(/databases/$(database)/documents/employees/$(nomina));
    }
    function esAdmin() {
      return estaConectado() &&
        existeEmpleado(miNomina()) &&
        get(/databases/$(database)/documents/employees/$(miNomina())).data.isAdmin == true;
    }
    function yaHayConfiguracionInicial() {
      return exists(/databases/$(database)/documents/meta/setup);
    }

    // Datos de empleados.
    // - "get" (leer UN empleado por su nómina) es público: lo necesita la
    //   pantalla de login para validar el número de nómina ANTES de que
    //   la persona tenga sesión iniciada.
    // - "list" (ver la lista completa de empleados) sí requiere sesión.
    // - Crear/editar/borrar normalmente solo lo puede hacer el admin,
    //   EXCEPTO la primera vez: se permite crear la cuenta admin inicial
    //   mientras no exista todavía el documento meta/setup.
    match /employees/{nomina} {
      allow get: if true;
      allow list: if estaConectado();
      allow create: if esAdmin() ||
        (!yaHayConfiguracionInicial() &&
         estaConectado() &&
         request.resource.data.nomina == miNomina() &&
         request.resource.data.isAdmin == true);
      allow update, delete: if esAdmin();
    }

    // Documento "candado" que marca que ya se creó el primer administrador.
    match /meta/setup {
      allow get: if true;
      allow create: if estaConectado() && !yaHayConfiguracionInicial();
      allow update, delete: if esAdmin();
    }

    // Solicitudes de vacaciones: un empleado solo puede crear solicitudes
    // a su propio nombre y leer las suyas. El administrador puede leer,
    // aprobar o rechazar cualquiera.
    match /requests/{requestId} {
      allow read: if estaConectado() && (esAdmin() || resource.data.nomina == miNomina());
      allow create: if estaConectado() && request.resource.data.nomina == miNomina();
      allow update, delete: if esAdmin();
    }
  }
}
